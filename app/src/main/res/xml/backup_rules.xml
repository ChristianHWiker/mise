<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto Backup rules for Android 11 and below. The Android 12+ flow uses
  data_extraction_rules.xml instead — keep the two in sync where they overlap.
  See https://developer.android.com/guide/topics/data/autobackup for the schema.
-->
<full-backup-content>
    <!-- Include: user content the user would want restored on a fresh install. -->
    <include domain="database" path="recipe.db"/>
    <include domain="file" path="recipe_photos/"/>
    <include domain="sharedpref" path="settings.xml"/>

    <!-- Exclude: device-bound or transient. -->
    <!--   secure_prefs holds values encrypted with a Keystore key bound to THIS device;
           the ciphertext is unreadable on any other device, so backing it up is dead weight. -->
    <exclude domain="sharedpref" path="secure_prefs.xml"/>
    <!--   OCR captures are working-set temp files; the user has no reason to want them synced. -->
    <exclude domain="file" path="ocr_captures/"/>
</full-backup-content>
